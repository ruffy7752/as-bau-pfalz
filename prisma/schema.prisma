generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Visit {
  id        Int      @id @default(autoincrement())
  day       String   @unique
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model TotalVisit {
  id        Int      @id @default(1)
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model ContactRequest {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}